# =====================================================================
# Offcampuscareer — Apache .htaccess
# Domain: tip.offcampuscareer.com
# Purpose: React SPA routing + PHP API + HTTPS + Security headers
# =====================================================================

Options -Indexes
DirectoryIndex index.html

# ── HTTPS Redirect ──────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} tip.offcampuscareer.com [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # ── PHP API Routing ─────────────────────────────────────────────
    # Pass /api/* requests directly to PHP files (no rewrite needed if files exist)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^api/.*\.php$ - [L]

    # ── React Router SPA Fallback ───────────────────────────────────
    # For any request that is NOT an existing file or directory,
    # serve index.html so React Router can handle it client-side
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/api/
    RewriteRule ^ /index.html [L]
</IfModule>

# ── Security Headers ────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # XSS Protection (legacy browsers)
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Content Security Policy — adjust if you add external resources
    Header always set Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://tip.offcampuscareer.com;"

    # Remove Server header info
    Header always unset Server
</IfModule>

# ── Static Asset Caching ────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML — short cache (React app may update)
    ExpiresByType text/html "access plus 1 hour"

    # CSS and JS (Vite adds content hashes, so long cache is safe)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"

    # Images
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"

    # Fonts
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# ── Compression (Gzip) ──────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# ── PHP Security ────────────────────────────────────────────────────
<IfModule mod_php.c>
    # Disable PHP error display in production (log them instead)
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_log /home/logs/occ_php_errors.log
</IfModule>

# ── Protect Sensitive Files ─────────────────────────────────────────
<FilesMatch "(\.db|\.sql|\.env|\.gitignore|\.log|composer\.(json|lock)|package\.json)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block direct access to the db directory
<IfModule mod_rewrite.c>
    RewriteRule ^db/ - [F,L]
    RewriteRule ^ai/ - [F,L]
</IfModule>
